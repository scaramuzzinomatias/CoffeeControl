{
  "name": "coffeecontrol-backend",
  "version": "2.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "node scripts/db-init.js",
    "db:migrate": "node scripts/db-migrate-all.js",
    "db:migrate:all": "node scripts/db-migrate-all.js",
    "support:doctor": "node scripts/support-doctor.js",
    "support:user": "node scripts/support-user.js",
    "support:reset-admin": "node scripts/support-user.js --username admin --role admin --activate",
    "support:create-supervisor": "node scripts/support-user.js --role supervisor --activate",
    "support:create-technician": "node scripts/support-user.js --role tecnico --activate",
    "test:integration": "node --test test/integration.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.0",
    "pg": "^8.11.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
