# CoffeeControl — plantilla .env por cliente
# Copiar este archivo a backend/.env en la instalación de cada empresa
# y completar valores propios del cliente.

# Identidad de la instalación
CLIENT_SLUG=empresa_demo
CLIENT_NAME=Empresa Demo

# PostgreSQL
# Recomendación: una base por empresa
DATABASE_URL=postgresql://usuario:password@127.0.0.1:5432/coffeecontrol_empresa_demo

# Servidor
PORT=3000
NODE_ENV=production
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires

# Seguridad
JWT_SECRET=cambiar-por-jwt-seguro-y-largo
REGISTRATION_SECRET=cambiar-por-registro-seguro-y-unico-por-cliente

# Alertas por email
ALERT_EMAIL_TO=operaciones@empresa.com
ALERT_EMAIL_FROM=coffeecontrol@empresa.com
SMTP_HOST=smtp.empresa.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=coffeecontrol@empresa.com
SMTP_PASS=cambiar-por-password
ALERT_CHECK_INTERVAL_MS=60000

# Opcionales de operación
# DISABLE_ALERT_MONITOR=false
# PG_BIN=C:\Program Files\PostgreSQL\15\bin
