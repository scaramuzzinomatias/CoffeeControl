# CoffeeControl — Variables de entorno
# Copiar como .env y completar los valores
# Para instalaciones por cliente, ver también:
# - backend/.env.client.example
# - PLANTILLA_DESPLIEGUE_CLIENTE.md

# Identidad de la instalación
CLIENT_SLUG=empresa_demo
CLIENT_NAME=Empresa Demo

# PostgreSQL — tres roles con distintos niveles de acceso:
#
# DATABASE_URL           — (coffeecontrol_app)    Runtime de la app, sujeto a RLS.
#                          Todas las routes y services usan este pool.
# DATABASE_URL_BOOTSTRAP — (coffeecontrol_bootstrap) BYPASSRLS para queries de
#                          arranque (login, lookup de máquina por MAC).
#                          Solo 3 conexiones máx. No usarlo en routes normales.
# DATABASE_URL_OWNER     — (coffeecontrol_owner)  Dueño de tablas, bypasea RLS.
#                          Solo scripts de administración (db-*, support-*).
#
# Los tres roles se crean con backend/sql/roles_setup.sql

DATABASE_URL=postgresql://coffeecontrol_app:password@localhost:5432/coffeecontrol
DATABASE_URL_BOOTSTRAP=postgresql://coffeecontrol_bootstrap:password@localhost:5432/coffeecontrol
DATABASE_URL_OWNER=postgresql://coffeecontrol_owner:password@localhost:5432/coffeecontrol

# Servidor
PORT=3000
NODE_ENV=development
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires

# Seguridad del backend
JWT_SECRET=cambiar-por-jwt-seguro-y-largo

# Secret compartido con el firmware ESP para el auto-registro
# Debe coincidir con REGISTRATION_SECRET en el firmware
REGISTRATION_SECRET=cambiar-por-clave-segura

# Notificaciones por email
# ALERT_EMAIL_TO define destinatarios operativos globales (por ejemplo, máquina offline).
# Las advertencias preventivas por límite usan el email del empleado y supervisores de su área.
ALERT_EMAIL_TO=operaciones@empresa.com
ALERT_EMAIL_FROM=coffeecontrol@empresa.com
SMTP_HOST=smtp.empresa.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=coffeecontrol@empresa.com
SMTP_PASS=cambiar-por-password
ALERT_CHECK_INTERVAL_MS=60000
